{
	"$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
	"files": {
		"includes": ["**", "!*.md", "!build", "!.svelte-kit", "!.claude", "!static/piano-mp3"]
	},
	"formatter": {
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"trailingCommas": "all"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			// Biome can't see Svelte template usage — these produce false positives
			"correctness": {
				"noUnusedVariables": "off",
				"noUnusedImports": "off",
				"noUnusedFunctionParameters": "off",
				"noSelfAssign": "warn"
			},
			"suspicious": {
				"noExplicitAny": "off",
				// Used intentionally in renderMarkdown regex
				"noControlCharactersInRegex": "off",
				// Used for ||= init patterns
				"noAssignInExpressions": "off",
				"noImplicitAnyLet": "off"
			},
			"complexity": {
				"noBannedTypes": "off"
			},
			"style": {
				"noNonNullAssertion": "off"
			}
		}
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
